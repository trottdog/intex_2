# Copy to .env.local (gitignored). Vite loads .env.local automatically.
# Frontend talks to the Azure-hosted .NET API only. Do not put database secrets here.

# Optional: .NET API base URL (no trailing slash).
# If unset in dev, the app uses same-origin `/api` (Vite proxy → http://localhost:4000).
# Set explicitly only when the API is on another host/port.
# VITE_API_BASE_URL=http://localhost:4000
