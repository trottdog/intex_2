# Copy to .env.development.local (gitignored) for local `npm run dev` only.
# Using .env.development.local avoids baking a dev API URL into `npm run build` output.
# Do not put database secrets here.

# API base URL (no trailing slash). Paths are like /auth/login, /residents - not /api/auth/...
#
# Local API (default when unset in dev): same-origin /api -> Vite proxy -> http://localhost:4000
# VITE_API_BASE_URL=http://localhost:4000
#
# Production default on Vercel: leave unset or set `/api` and use a rewrite/proxy to the backend.
# This keeps cookie auth first-party on the frontend domain.
# VITE_API_BASE_URL=/api
#
# Direct cross-site Azure API calls are still possible, but cookie auth becomes third-party and
# may be blocked by modern browsers even when CORS + SameSite=None are configured:
# VITE_API_BASE_URL=https://intex-gtgzecb5avarh7gg.centralus-01.azurewebsites.net
#
# Production static hosting (`npm run build`): use committed `frontend/.env.production` or set the same
# variable in CI. Never ship a build that points to localhost - HTTPS sites cannot call loopback.
