# Copy to .env.development.local (gitignored) for local `npm run dev` only.
# Using .env.development.local avoids baking a dev API URL into `npm run build` output.
# Do not put database secrets here.

# API base URL (no trailing slash). Paths are like /auth/login, /residents — not /api/auth/...
#
# Local API (default when unset in dev): same-origin /api → Vite proxy → http://localhost:4000
# VITE_API_BASE_URL=http://localhost:4000
#
# Deployed API from localhost dev server (requires Azure CORS + Auth:Cookie:CrossSite on the API):
# VITE_API_BASE_URL=https://intex2-a6d7e5dnave8hzd5.francecentral-01.azurewebsites.net
