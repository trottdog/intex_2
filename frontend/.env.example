# Copy to .env.local (gitignored). Vite loads .env.local automatically.
# Same names as Supabase + Next.js docs; vite.config.ts sets envPrefix for NEXT_PUBLIC_.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key_here

# Optional: .NET API base URL (no trailing slash).
VITE_API_BASE_URL=https://localhost:7117
