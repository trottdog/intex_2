# Copy to .env (gitignored). Loaded at startup via DotNetEnv.
#
# Prefer this Npgsql form (pooler). Avoid postgresql://...?sslmode=require in .env — the "=" in the
# query string is often truncated by env/config tooling, which breaks Npgsql with errors like
# "Couldn't set postgresql://...?sslmode".

Supabase__Url=https://YOUR_PROJECT_REF.supabase.co

# Transaction pooler (6543): Program.cs enforces pooler-safe Npgsql flags (no auto-prepare, no reset-on-close,
# no multiplexing, connection lifetime). If requests still fail after the first success, switch local dev to the
# direct connection: Host=db.YOUR_PROJECT_REF.supabase.co;Port=5432;Username=postgres
ConnectionStrings__DefaultConnection=Host=YOUR_POOLER_HOST;Port=6543;Database=postgres;Username=postgres.YOUR_PROJECT_REF;Password=YOUR_DATABASE_PASSWORD;SSL Mode=Require;Trust Server Certificate=true;Max Auto Prepare=0

# Example: Host=aws-0-us-east-2.pooler.supabase.com (use the host from your Supabase dashboard).
