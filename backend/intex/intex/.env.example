# Copy to .env (gitignored). Loaded at startup via DotNetEnv.
#
# Prefer this Npgsql form (pooler). Avoid postgresql://...?sslmode=require in .env — the "=" in the
# query string is often truncated by env/config tooling, which breaks Npgsql with errors like
# "Couldn't set postgresql://...?sslmode".

Supabase__Url=https://YOUR_PROJECT_REF.supabase.co

# Transaction pooler (6543): good for read-heavy API traffic. EF migrations and Identity *startup seed* are skipped
# on 6543 (see Program.cs). For `dotnet ef database update` or seeded demo logins, use direct Postgres once:
#
#   Host=db.YOUR_PROJECT_REF.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true
#
# Or run identity-schema-update.sql / identity-seed.sql in the Supabase SQL Editor.
ConnectionStrings__DefaultConnection=Host=YOUR_POOLER_HOST;Port=6543;Database=postgres;Username=postgres.YOUR_PROJECT_REF;Password=YOUR_DATABASE_PASSWORD;SSL Mode=Require;Trust Server Certificate=true;Max Auto Prepare=0

# Example pooler host: aws-0-us-east-2.pooler.supabase.com (from Supabase Dashboard → Database → Connection string).
